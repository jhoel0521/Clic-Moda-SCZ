# ──────────────────────────────────────────────
# CONFIGURACIÓN DE LA TIENDA — Clic Moda SCZ
# Copiá este archivo a .env.local y completá
# los valores reales. .env.local NO se sube a git.
# ──────────────────────────────────────────────

NEXT_PUBLIC_STORE_NAME=Clic Moda SCZ

# Número de WhatsApp para coordinación de pedidos (formato internacional, sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=591000000000

# ── Dirección / info de la tienda ──────────────
NEXT_PUBLIC_STORE_ADDRESS=Av. Ejemplo 123, Santa Cruz de la Sierra

# ── Datos bancarios para transferencia ─────────
# Banco donde los clientes realizan el depósito
NEXT_PUBLIC_BANK_NAME=Banco Nacional de Bolivia
# Número de cuenta bancaria
NEXT_PUBLIC_BANK_ACCOUNT=000000000000
# Nombre del titular de la cuenta
NEXT_PUBLIC_BANK_HOLDER=Nombre Titular Cuenta
# CI o NIT del titular
NEXT_PUBLIC_BANK_CI=12345678

# ── Pago por QR ────────────────────────────────
# URL de la imagen QR que genera tu app bancaria para cobros
# Podés subir la imagen a cualquier hosting (Google Drive, Imgur, etc.)
NEXT_PUBLIC_PAYMENT_QR_URL=https://ejemplo.com/mi-qr-de-cobro.png

# ── Configuración técnica ──────────────────────
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_USE_SIMULATED_BACKEND=true
